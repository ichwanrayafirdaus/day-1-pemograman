{
  "$schema": "https://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "${icon}",
                  "width": "36px",
                  "height": "36px"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${appName}",
                  "weight": "Bolder",
                  "size": "Medium",
                  "color": "Accent"
                },
                {
                  "type": "TextBlock",
                  "text": "${period}",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Pemasukan",
              "size": "Small",
              "isSubtle": true
            },
            {
              "type": "TextBlock",
              "text": "${income}",
              "weight": "Bolder",
              "color": "Good",
              "spacing": "None"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Pengeluaran",
              "size": "Small",
              "isSubtle": true
            },
            {
              "type": "TextBlock",
              "text": "${expense}",
              "weight": "Bolder",
              "color": "Attention",
              "spacing": "None"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Laba Bersih",
              "size": "Small",
              "isSubtle": true
            },
            {
              "type": "TextBlock",
              "text": "${profit}",
              "weight": "Bolder",
              "color": "Accent",
              "spacing": "None"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Buka TOKO KITA",
      "url": "https://ichwanrayafirdaus.github.io/day-1-pemograman/"
    }
  ]
}
